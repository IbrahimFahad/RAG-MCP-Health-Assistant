# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Tavily Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# OpenWeatherMap (Outdoor Activity Advisor — free tier works)
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Firecrawl (optional - fallback to BeautifulSoup)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Azure Document Intelligence (for Arabic PDF OCR)
AZURE_DOC_INTEL_ENDPOINT=your_azure_endpoint_here
AZURE_DOC_INTEL_KEY=your_azure_key_here

# App Settings
SIMILARITY_THRESHOLD=0.75
TOP_K_RESULTS=3
EMBEDDING_MODEL=intfloat/multilingual-e5-large
